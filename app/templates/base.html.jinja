    <script src="{{ url_for('static', filename='js/jarallax.js') }}"></script>
    <script src="{{ url_for('static', filename='js/navbar-dropdown.js') }}"></script>
    <script src="{{ url_for('static', filename='js/smooth-scroll.js') }}"></script>
    <script src="{{ url_for('static', filename='js/theme.js') }}"></script>
    <script src="{{ url_for('static', filename='js/yt-player.js') }}"></script>
