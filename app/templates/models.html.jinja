>
    <div
        class="mbr-overlay"
        style="opacity: 0.8; background-color: rgb(35, 35, 35)"
    ></div>

    <div class="align-center container-fluid">
        <div class="row justify-content-center">
            <div class="col-12 col-lg-12">
                <h1 class="mbr-section-title mb-3 display-1">
                    <strong>{{ _("Model Hub") }}</strong>
                </h1>

                <p class="mbr-text display-5">
                    Welcome to the Download hub!<br />Here you can find all the
                    Bestboi official and community model downloads. Select a
                    model version or category and go to its download page.
                </p>
