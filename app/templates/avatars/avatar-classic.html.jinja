{% extends "base.html.jinja" %}
{% block title %}{{ _("Bestboi Classic") }}{% endblock %}
{% block content %}
    <section data-bs-version="5.1"
             class="header11 cid-t8Rdb69O3e mbr-fullscreen mbr-parallax-background"
             id="header11-2f">
        <script type="module"
                src="https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js"></script>
        <div class="mbr-overlay"
             style="opacity: 0.8;
                    background-color: rgb(35, 35, 35)"></div>
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-12 col-md-6 image-wrapper">
                    <style>
                    model-viewer#reveal {
                        --poster-color: transparent;
                    }
                    </style>
                    <model-viewer id="reveal" loading="eager" bounds="tight" enable-pan="" src="{{ url_for("static", filename="models/classic.glb") }}" camera-controls="" environment-image="neutral" poster="{{ url_for("static", filename="models/classic_poster.png") }}" shadow-intensity="1">
                    <div class="progress-bar hide" slot="progress-bar">
                        <div class="update-bar"></div>
                        <script type="module"
                                src="{{ url_for("static", filename="js/progress-bar.js") }}"></script>
                    </div>
                    </model-viewer>
                </div>
                <div class="col-12 col-md">
                    <div class="text-wrapper text-center">
                        <h1 class="mbr-section-title mb-3 display-2">
                            <strong>{{ _("Bestboi Classic") }}</strong>
                        </h1>
                        {#<p class="mbr-text display-7">
                        <em
                            >The original bestboi, the real OG that started it
                            all<br /></em
                        >You can move the preview on the right!
                    </p>#}
                        <div class="mbr-section-btn mt-3">
                            <a class="btn btn-secondary display-7"
                               href="https://assets.bestbois.com/api/download/bestboi_classic"><span class="material material-file-download mbr-iconfont mbr-iconfont-btn"></span>{{ _("Download") }}</a>
                            <a class="btn btn-secondary display-7"
                               href="https://zexc.gumroad.com/l/BestboiClassic"><span class="material material-file-download mbr-iconfont mbr-iconfont-btn"></span>{{ _("Download on %(platform)s", platform="Gumroad") }}</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
